{
  "title": "Qwen Image Edit Lightning",
  "description": "Serverless worker для lightx2v/Qwen-Image-Edit-2511-Lightning. Работает на ЛЮБЫХ GPU (RTX 4090, RTX 5090, A100, A6000, L40S, 3090 и т.д.). GPU Type выбирайте сами в настройках Endpoint — ограничений нет.",
  "type": "serverless",
  "category": "image",
  "config": {
    "runsOn": "GPU",
    "endpointType": "LB",
    "containerDiskInGb": 150,
    "gpuCount": 1,
    "allowedCudaVersions": [
      "12.8",
      "12.7",
      "12.6",
      "12.5",
      "12.4"
    ],
    "env": [
      {
        "key": "QWEN_MODEL_ID",
        "input": {
          "type": "string",
          "name": "Base model ID",
          "description": "Базовая модель",
          "default": "Qwen/Qwen-Image-Edit-2511",
          "required": true
        }
      },
      {
        "key": "LORA_REPO_ID",
        "input": {
          "type": "string",
          "name": "LoRA repo ID",
          "description": "Lightning LoRA репозиторий",
          "default": "lightx2v/Qwen-Image-Edit-2511-Lightning",
          "required": true
        }
      },
      {
        "key": "LORA_WEIGHT_NAME",
        "input": {
          "type": "string",
          "name": "LoRA weight name",
          "description": "Имя .safetensors файла",
          "default": "Qwen-Image-Edit-2511-Lightning-8steps-V1.0-fp32.safetensors",
          "required": true
        }
      },
      {
        "key": "MODEL_STORAGE_PATH",
        "input": {
          "name": "Model storage path",
          "type": "string",
          "description": "Путь для кэша моделей",
          "default": "/workspace/model-storage",
          "advanced": true
        }
      },
      {
        "key": "MIN_STORAGE_FREE_GB",
        "input": {
          "name": "Minimum free storage",
          "type": "number",
          "description": "Минимально свободного места на диске",
          "default": 80,
          "min": 60,
          "max": 500,
          "advanced": true
        }
      },
      {
        "key": "HF_DOWNLOAD_MAX_WORKERS",
        "input": {
          "name": "Download concurrency",
          "type": "number",
          "description": "Количество потоков скачивания",
          "default": 4,
          "min": 1,
          "max": 8,
          "advanced": true
        }
      },
      {
        "key": "HF_XET_CHUNK_CACHE_SIZE_BYTES",
        "value": "0"
      },
      {
        "key": "HF_XET_SHARD_CACHE_SIZE_LIMIT",
        "value": "1073741824"
      },
      {
        "key": "RUNPOD_INIT_TIMEOUT",
        "value": "1800"
      }
    ],
    "presets": [
      {
        "name": "Any GPU (24GB+)",
        "defaults": {
          "QWEN_MODEL_ID": "Qwen/Qwen-Image-Edit-2511",
          "LORA_REPO_ID": "lightx2v/Qwen-Image-Edit-2511-Lightning",
          "LORA_WEIGHT_NAME": "Qwen-Image-Edit-2511-Lightning-8steps-V1.0-fp32.safetensors",
          "MODEL_STORAGE_PATH": "/workspace/model-storage",
          "MIN_STORAGE_FREE_GB": 80
        }
      }
    ]
  }
}
